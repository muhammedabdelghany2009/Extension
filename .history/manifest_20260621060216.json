{
    "manifest_version": 3,
    "name": "My YT Bookmarks - الاحترافي",
    "version": "1.0.0",
    "description": "إضافة احترافية ومطورة لحفظ العلامات المرجعية وتكرار لقطات فيديوهات اليوتيوب بدقة.",
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "https://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.youtube.com/*"
            ],
            "js": [
                "contentScript.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/bookmark.png",
                "assets/play.png",
                "assets/delete.png",
                "assets/save.png"
            ],
            "matches": [
                "https://*.youtube.com/*"
            ]
        }
    ],
    "action": {
        "default_icon": {
            "16": "assets/ext-icon.png",
            "24": "assets/ext-icon.png",
            "32": "assets/ext-icon.png"
        },
        "default_title": "My YT Bookmarks",
        "default_popup": "popup.html"
    }
}
{
    "manifest_version": 3,
    "name": "YouTube Bookmarks Pro",
    "version": "2.0.0",
    "description": "إضافة متقدمة لحفظ العلامات المرجعية على فيديوهات يوتيوب",
    "permissions": [
        "storage",
        "activeTab",
        "tabs"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "assets/ext-icon.png",
            "48": "assets/ext-icon.png",
            "128": "assets/ext-icon.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://youtube.com/*"
            ],
            "js": [
                "contentScript.js"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*"
            ],
            "matches": [
                "https://www.youtube.com/*"
            ]
        }
    ]
}